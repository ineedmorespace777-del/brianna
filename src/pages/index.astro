---
import site from '../content/site.json';

// inline-markdown helpers: *x* → <em>x</em>, newlines split to <span> lines
const em = (s) => (s || '').replace(/\*([^*]+)\*/g, '<em>$1</em>');
const titleLines = (s) => (s || '').split('\n').map(l => `<span>${em(l)}</span>`).join('');
const inline = (s) => em(s);
const nl2br = (s) => (s || '').replace(/\n/g, '<br/>');

const cssVer = 'redesign-3';
const jsVer  = 'redesign-2';

const gate = site.comingSoon || {};
const showGate = gate.enabled !== false;

// double-up marquee items so the css translateX(-50%) animation loops seamlessly
const marqueeItems = [...site.marquee.items, ...site.marquee.items];

const showAboutMei = site.aboutMei && site.aboutMei.enabled !== false;
const showFaq      = site.faq && site.faq.enabled !== false && (site.faq.items || []).length > 0;

// ─────────────────────────── JSON-LD structured data ────────────────────────────
// Schema.org BeautySalon — gives Google a knowledge-panel-ready understanding of
// what this place is, where, when, how to reach it. Derives from site.json so
// Brianna's edits flow through without us touching code.
const seo = site.seo || {};
const loc0 = (site.locations && site.locations.items && site.locations.items[0]) || {};

// Map "tue — fri"-style day labels to schema.org day enums.
const DAY_MAP = {
  mon: 'Monday', tue: 'Tuesday', wed: 'Wednesday', thu: 'Thursday',
  fri: 'Friday', sat: 'Saturday', sun: 'Sunday',
};
function expandDayRange(label) {
  // accept things like "tue — fri", "saturday", "sun — mon"
  const norm = (label || '').toLowerCase().replace(/[—–-]/g, '-').replace(/\s+/g, '');
  const parts = norm.split('-');
  const lookup = (s) => DAY_MAP[s.slice(0, 3)];
  if (parts.length === 1) {
    const d = lookup(parts[0]);
    return d ? [d] : [];
  }
  const order = ['mon', 'tue', 'wed', 'thu', 'fri', 'sat', 'sun'];
  const start = order.indexOf(parts[0].slice(0, 3));
  const end   = order.indexOf(parts[1].slice(0, 3));
  if (start < 0 || end < 0) return [];
  const out = [];
  for (let i = start; i !== (end + 1) % 7; i = (i + 1) % 7) {
    out.push(DAY_MAP[order[i]]);
    if (i === end) break;
  }
  return out;
}
function parseHourValue(value) {
  // "10:00a — 7:00p" → { opens: "10:00", closes: "19:00" }
  if (!value || /closed/i.test(value)) return null;
  const segs = value.toLowerCase().replace(/[—–]/g, '-').split('-').map(s => s.trim());
  const toHHMM = (s) => {
    const m = s.match(/(\d{1,2})(?::(\d{2}))?\s*([ap])?/);
    if (!m) return null;
    let h = parseInt(m[1], 10);
    const mm = m[2] || '00';
    const ap = m[3];
    if (ap === 'p' && h < 12) h += 12;
    if (ap === 'a' && h === 12) h = 0;
    return String(h).padStart(2, '0') + ':' + mm;
  };
  const opens = toHHMM(segs[0]);
  const closes = toHHMM(segs[1] || '');
  if (!opens || !closes) return null;
  return { opens, closes };
}
const openingHours = (loc0.hours || []).flatMap(h => {
  const t = parseHourValue(h.value);
  if (!t) return [];
  const days = expandDayRange(h.label);
  if (!days.length) return [];
  return [{
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: days,
    opens: t.opens,
    closes: t.closes,
  }];
});
const siteUrl = seo.site_url || 'https://brianna.philipngo.ca';
// Business name for structured data — prefer the first segment of OG title
// (e.g. "mei skin studio — boutique restorative facials" → "mei skin studio"),
// fall back to the wordmark.
const bizName = ((site.meta.og_title || '').split(/[—–-]/)[0] || '').trim() || site.brand.name;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BeautySalon',
  name: bizName,
  description: site.meta.description,
  url: siteUrl,
  image: siteUrl + '/assets/mei-logo.png',
  logo: siteUrl + '/assets/mei-logo.png',
  priceRange: seo.price_range || '$$',
  address: {
    '@type': 'PostalAddress',
    streetAddress: seo.street_address || '',
    addressLocality: seo.locality || '',
    addressRegion: seo.region || '',
    addressCountry: seo.country || '',
  },
  ...(seo.latitude && seo.longitude ? {
    geo: { '@type': 'GeoCoordinates', latitude: seo.latitude, longitude: seo.longitude },
  } : {}),
  areaServed: seo.locality || 'Vancouver',
  sameAs: [site.brand.ig_url].filter(u => u && u !== '#'),
  openingHoursSpecification: openingHours,
};
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="theme-color" content={site.meta.theme_color} />

  {showGate && (
    <script is:inline>
      try {
        if (localStorage.getItem('mei-unlocked') === 'true') {
          document.documentElement.classList.add('unlocked');
        }
      } catch (e) { /* private mode etc. */ }
    </script>
  )}
  {!showGate && (
    <script is:inline>
      document.documentElement.classList.add('unlocked');
    </script>
  )}

  <meta name="description" content={site.meta.description} />
  <title>{site.meta.title}</title>

  <meta property="og:type" content="website" />
  <meta property="og:title" content={site.meta.og_title} />
  <meta property="og:description" content={site.meta.og_description} />
  <meta property="og:image" content="/assets/mei-logo.png" />
  <meta property="og:locale" content="en_US" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={site.meta.twitter_title} />
  <meta name="twitter:description" content={site.meta.twitter_description} />
  <meta name="twitter:image" content="/assets/mei-logo.png" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;1,9..144,300;1,9..144,400&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <link rel="icon" type="image/png" href="/assets/mei-logo.png" />
  <link rel="apple-touch-icon" href="/assets/mei-logo.png" />
  <link rel="canonical" href={siteUrl} />
  <link rel="stylesheet" href={`/styles/main.css?v=${cssVer}`} />

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>

  {showGate && (
    <script is:inline set:html={`window.__MEI_PWD=${JSON.stringify((gate.password || 'meiskin').toLowerCase())};`} />
  )}
</head>
<body>

  <a class="skip-link" href="#main">skip to content</a>

  {showGate && (
    <aside class="coming-soon-gate" id="coming-soon-gate" aria-label="coming soon">
      <div class="cs-inner">
        <img class="cs-logo" src="/assets/mei-logo.png" alt="mei skin studio" />
        <p class="cs-eyebrow">{gate.eyebrow}</p>
        {/* Use h2 — the gate is an <aside> overlay, not the document's primary outline.
            The hero <h1> below is the page's true heading. */}
        <h2 class="cs-title" set:html={inline(gate.title)}></h2>
        <p class="cs-sub">{gate.sub}</p>

        <form class="cs-form" id="cs-form" novalidate>
          <label for="cs-pwd" class="visually-hidden">password</label>
          <input id="cs-pwd" type="password"
                 placeholder="enter password"
                 autocomplete="off" autocapitalize="off" autocorrect="off" spellcheck="false"
                 required />
          <button type="submit" class="btn btn-primary">enter</button>
          <p class="cs-msg" role="status" aria-live="polite" hidden></p>
        </form>

        <a class="cs-ig" href={site.brand.ig_url} target="_blank" rel="noopener">
          {gate.ig_label}
        </a>
      </div>
    </aside>
  )}

  <header class="site-header" id="site-header">
    <div class="header-inner">
      <a class="brand" href="#top" aria-label={`${site.brand.name} — home`}>
        <img src="/assets/mei-logo.png" alt={site.brand.name} />
        <span class="brand-word">{site.brand.name}</span>
      </a>

      <a class="book-btn" href="#book" data-magnetic>book a visit</a>

      <button class="nav-toggle" id="nav-toggle" aria-controls="overlay-nav" aria-expanded="false" aria-label="open menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </header>

  <div class="overlay-nav" id="overlay-nav" hidden>
    <div class="overlay-nav-inner">
      <ul>
        {site.overlayNav.items.map(item => (
          <li><a href={item.anchor}><span>{item.label}</span></a></li>
        ))}
        <li><a class="overlay-book" href="#book"><em>{site.overlayNav.book_label}</em></a></li>
      </ul>
      <div class="overlay-foot">
        <span>{site.overlayNav.foot_left}</span>
        <span>{site.overlayNav.foot_right}</span>
      </div>
    </div>
  </div>

  <main id="main">

    <!-- hero ──────────────────────────────────────────────── -->
    <section class="hero" id="top">
      <div class="hero-inner">
        <p class="eyebrow reveal">{site.hero.eyebrow}</p>
        <h1 class="hero-title">
          {site.hero.title.split('\n').map(line => (
            <span class="line-mask"><span set:html={inline(line)}></span></span>
          ))}
        </h1>
        <p class="hero-sub reveal">{site.hero.sub}</p>
        <div class="hero-ctas reveal">
          <a class="btn btn-primary" href="#book" data-magnetic>{site.hero.cta_primary_label} <span class="btn-arrow">→</span></a>
          <a class="btn btn-pill" href="#experience">{site.hero.cta_secondary_label}</a>
        </div>
        {site.hero.meta && site.hero.meta.length > 0 && (
          <dl class="hero-meta reveal">
            {site.hero.meta.map(m => (
              <div><dt>{m.dt}</dt><dd>{m.dd}</dd></div>
            ))}
          </dl>
        )}
      </div>
      <div class="hero-media reveal" data-parallax="20">
        {site.hero.image ? (
          <img class="media-img" src={site.hero.image} alt={site.hero.image_alt || ''} loading="eager" fetchpriority="high" decoding="async" />
        ) : (
          <div class={`frame ${site.hero.frame_tint || ''}`}>
            {site.hero.frame_label && <span class="frame-label">{site.hero.frame_label}</span>}
          </div>
        )}
        {site.hero.chip_label && (
          <div class="hero-chip"><span class="dot"></span> {site.hero.chip_label}</div>
        )}
      </div>
    </section>

    <!-- marquee ───────────────────────────────────────────── -->
    <div class="marquee" aria-hidden="true">
      <div class="marquee-track">
        {marqueeItems.map(s => <span>{s}</span>)}
      </div>
    </div>

    <!-- philosophy ────────────────────────────────────────── -->
    <section class="philosophy" id="experience">
      <div class="container">
        <p class="eyebrow reveal">{site.philosophy.eyebrow}</p>
        <h2 class="section-title reveal" set:html={titleLines(site.philosophy.title).replace('</span><span>', '</span><br/><span>')}></h2>
        <p class="section-lede reveal">{site.philosophy.lede}</p>
        <div class="triad">
          {site.philosophy.triad.map(card => (
            <article class="triad-card reveal">
              <div class="triad-num">{card.num}</div>
              <h3 set:html={inline(card.title)}></h3>
              <p>{card.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- studio split ──────────────────────────────────────── -->
    <section class="experience-split" aria-labelledby="exp-h">
      <div class="exp-img reveal" data-parallax="22">
        {site.studioSplit.image ? (
          <img class="media-img" src={site.studioSplit.image} alt={site.studioSplit.image_alt || ''} loading="lazy" decoding="async" />
        ) : (
          <div class={`frame ${site.studioSplit.frame_tint || ''}`}>
            {site.studioSplit.frame_label && <span class="frame-label">{site.studioSplit.frame_label}</span>}
          </div>
        )}
      </div>
      <div class="exp-text">
        <p class="eyebrow reveal">{site.studioSplit.eyebrow}</p>
        <h2 class="section-title reveal" id="exp-h" set:html={inline(site.studioSplit.title)}></h2>
        <p class="reveal">
          {site.studioSplit.body_p1_before_link}<a class="link" href={site.studioSplit.body_p1_link_url} target="_blank" rel="noopener">{site.studioSplit.body_p1_link_text}</a>{site.studioSplit.body_p1_after_link}
        </p>
        <p class="reveal">{site.studioSplit.body_p2}</p>
        <a class="btn btn-pill reveal" href="#book">{site.studioSplit.cta_label}</a>
      </div>
    </section>

    <!-- meet mei ──────────────────────────────────────────── -->
    {showAboutMei && (
      <section class="meet-mei" id="meet-mei" aria-labelledby="meet-mei-h">
        <div class="container meet-mei-grid">
          <div class="meet-mei-text">
            <p class="eyebrow reveal">{site.aboutMei.eyebrow}</p>
            <h2 class="section-title reveal" id="meet-mei-h" set:html={inline(site.aboutMei.title)}></h2>
            <p class="meet-mei-lede reveal">{site.aboutMei.lede}</p>
            <p class="reveal">{site.aboutMei.body}</p>

            {site.aboutMei.pull_quote && (
              <blockquote class="meet-mei-quote reveal">
                <span class="qmark" aria-hidden="true">"</span>{site.aboutMei.pull_quote}
              </blockquote>
            )}

            {site.aboutMei.credentials && site.aboutMei.credentials.length > 0 && (
              <dl class="meet-mei-credentials reveal" aria-label="credentials">
                {site.aboutMei.credentials.map(c => (
                  <div>
                    <dt>{c.label}</dt>
                    <dd>{c.org}</dd>
                  </div>
                ))}
              </dl>
            )}

            {site.aboutMei.cta_label && (
              <a class="btn btn-primary reveal" href="#book" data-magnetic>
                {site.aboutMei.cta_label} <span class="btn-arrow">→</span>
              </a>
            )}
          </div>

          <div class="meet-mei-media reveal" data-parallax="18">
            {site.aboutMei.image ? (
              <img class="media-img" src={site.aboutMei.image} alt={site.aboutMei.image_alt || `${site.brand.name} — practitioner portrait`} loading="lazy" decoding="async" />
            ) : (
              <div class="frame">
                {site.aboutMei.frame_label && <span class="frame-label">{site.aboutMei.frame_label}</span>}
              </div>
            )}
          </div>
        </div>
      </section>
    )}

    <!-- menu ──────────────────────────────────────────────── -->
    <section class="menu" id="menu">
      <div class="container">
        <div class="menu-head">
          <div>
            <p class="eyebrow reveal">{site.services.eyebrow}</p>
            <h2 class="section-title reveal">{site.services.title}</h2>
          </div>
          {site.services.note && <p class="menu-note reveal">{site.services.note}</p>}
        </div>

        <div class="menu-grid">
          {site.services.items.map(s => (
            <article class="menu-card reveal">
              <div class="menu-card-img" data-parallax="14">
                {s.image ? (
                  <img class="media-img" src={s.image} alt={s.image_alt || s.name} loading="lazy" decoding="async" />
                ) : (
                  <div class={`frame ${s.tint || ''}`}></div>
                )}
                {s.price && <span class="price-tag">{s.price}</span>}
              </div>
              <div class="menu-card-body">
                <div class="menu-card-head">
                  <h3>{s.name}</h3>
                  <span class="menu-card-meta">{s.duration}</span>
                </div>
                <p>{s.description}</p>
              </div>
            </article>
          ))}
        </div>

        <div class="menu-footnote reveal">
          <p>{site.services.footnote}</p>
          <a class="btn btn-primary" href="#book" data-magnetic>{site.services.footnote_cta_label} <span class="btn-arrow">→</span></a>
        </div>
      </div>
    </section>

    <!-- atmosphere ────────────────────────────────────────── -->
    <section class="atmosphere">
      {site.atmosphere.image ? (
        <img class="media-img atmosphere-img" src={site.atmosphere.image} alt={site.atmosphere.image_alt || ''} data-parallax="30" loading="lazy" decoding="async" />
      ) : (
        <div class={`frame ${site.atmosphere.frame_tint || ''}`} data-parallax="30" aria-hidden="true"></div>
      )}
      <div class="atmosphere-overlay"></div>
      <div class="container atmosphere-inner">
        <h2 class="atmosphere-title reveal" set:html={inline(site.atmosphere.title)}></h2>
        <p class="reveal">{site.atmosphere.body}</p>
      </div>
    </section>

    <!-- testimonials ──────────────────────────────────────── -->
    <section class="testimonials">
      <div class="container">
        <p class="eyebrow reveal">{site.testimonials.eyebrow}</p>
        <h2 class="section-title reveal">{site.testimonials.title}</h2>
        <div class="reflections">
          {site.testimonials.items.map(t => (
            <figure class="reflection reveal">
              <blockquote>{t.quote}</blockquote>
              <figcaption>— {t.name}</figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>

    <!-- locations ─────────────────────────────────────────── -->
    <section class="locations" id="locations">
      <div class="container">
        <p class="eyebrow reveal">{site.locations.eyebrow}</p>
        <h2 class="section-title reveal" set:html={inline(site.locations.title)}></h2>

        {site.locations.items.map(loc => (
          <div class="loc-grid">
            <div class="loc-img reveal" data-parallax="18">
              {loc.image ? (
                <img class="media-img" src={loc.image} alt={loc.image_alt || `${loc.city_tag || site.brand.name} studio`} loading="lazy" decoding="async" />
              ) : (
                <div class={`frame ${loc.frame_tint || ''}`}>
                  {loc.frame_label && <span class="frame-label">{loc.frame_label}</span>}
                </div>
              )}
            </div>
            <div class="loc-body reveal">
              <span class="loc-city-tag">{loc.city_tag}</span>
              <h3 set:html={inline(loc.name)}></h3>
              <p class="loc-address" set:html={nl2br(loc.address)}></p>
              <dl class="loc-hours">
                {loc.hours.map(h => (
                  <>
                    <dt>{h.label}</dt><dd>{h.value}</dd>
                  </>
                ))}
              </dl>
              <div class="loc-ctas">
                <a class="btn btn-primary" href={loc.cta_primary_url} data-magnetic>{loc.cta_primary_label} <span class="btn-arrow">→</span></a>
                <a class="btn btn-pill" href={loc.cta_secondary_url}>{loc.cta_secondary_label}</a>
              </div>
            </div>
          </div>
        ))}

        <p class="hours-line reveal">
          {site.locations.contact_line_label} · <a href={`mailto:${site.locations.contact_email}`}>{site.locations.contact_email}</a>
        </p>
      </div>
    </section>

    <!-- faq ───────────────────────────────────────────────── -->
    {showFaq && (
      <section class="faq" id="faq" aria-labelledby="faq-h">
        <div class="container">
          <p class="eyebrow reveal">{site.faq.eyebrow}</p>
          <h2 class="section-title reveal" id="faq-h" set:html={inline(site.faq.title)}></h2>

          <div class="faq-list reveal">
            {site.faq.items.map((item, i) => (
              <details class="faq-item" name="faq-group">
                <summary>
                  <span class="faq-q">{item.q}</span>
                  <span class="faq-icon" aria-hidden="true">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                      <path d="M3 6l5 5 5-5" />
                    </svg>
                  </span>
                </summary>
                <div class="faq-a">
                  <p>{item.a}</p>
                </div>
              </details>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- newsletter / book ─────────────────────────────────── -->
    <section class="newsletter" id="book">
      <div class="container">
        <div class="newsletter-grid reveal">
          <div class="newsletter-text">
            <p class="eyebrow">{site.newsletter.eyebrow}</p>
            <h2 class="section-title" set:html={inline(site.newsletter.title)}></h2>
            <p>{site.newsletter.body}</p>
          </div>
          <form class="newsletter-form" id="newsletter-form" novalidate>
            <label for="nl-name" class="visually-hidden">first name</label>
            <input id="nl-name" name="name" type="text" placeholder={site.newsletter.name_placeholder} autocomplete="given-name" required />

            <label for="nl-email" class="visually-hidden">email</label>
            <input id="nl-email" name="email" type="email" placeholder={site.newsletter.email_placeholder} autocomplete="email" required />

            <button type="submit" class="btn btn-primary btn-block">{site.newsletter.submit_label}</button>
            <p class="form-msg" role="status" aria-live="polite" hidden></p>
          </form>
        </div>
      </div>
    </section>

  </main>

  <footer class="site-footer" id="memberships">
    <div class="container footer-grid">
      <div class="footer-brand">
        <a class="brand" href="#top" aria-label={site.brand.name}>
          <img src="/assets/mei-logo.png" alt={site.brand.name} />
        </a>
        <p>{site.footer.tagline}</p>
      </div>

      {site.footer.columns.map(col => (
        <nav class="footer-nav" aria-label={col.heading}>
          <h4>{col.heading}</h4>
          <ul>
            {col.items.map(item => (
              <li><a href={item.url}>{item.label}</a></li>
            ))}
          </ul>
        </nav>
      ))}

      <div class="footer-social">
        <h4>follow</h4>
        <ul>
          <li><a href={site.brand.ig_url} target="_blank" rel="noopener" aria-label="instagram">ig</a></li>
          <li><a href={site.brand.tiktok_url} aria-label="tiktok">tt</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-base">
      <div class="container footer-base-inner">
        <small>© <span id="yr"></span> {site.footer.copyright_name}. all rights reserved.</small>
        <small>
          {site.footer.legal_links.map((l, i) => (
            <>{i > 0 && ' · '}<a href={l.url}>{l.label}</a></>
          ))}
          <span class="admin-sep"> · </span><a class="admin-link" href="/admin/">admin</a>
        </small>
      </div>
    </div>
  </footer>

  <!-- sticky mobile book bar -->
  <div class="book-bar" id="book-bar">
    <a class="btn btn-primary" href="#book">book a visit <span class="btn-arrow">→</span></a>
  </div>

  <script src={`/scripts/main.js?v=${jsVer}`} defer></script>

  {/* Vercel Web Analytics + Speed Insights — auto-served at /_vercel/* on Vercel
       deploys. 404s gracefully on local preview. Enable in Vercel project
       Settings → Analytics + Speed Insights. */}
  <script defer src="/_vercel/insights/script.js"></script>
