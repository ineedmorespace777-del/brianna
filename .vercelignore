# Keep deploy slim AND deterministic — exclude dev-only artifacts and
# anything that gets regenerated server-side during the build.
# Vercel's auto-deploy ignores this file (it pulls fresh from GitHub),
# but the Vercel CLI uses it when uploading the working directory.

# package managers
node_modules

# build outputs (regenerated by Vercel on every deploy)
dist
.astro
tina/__generated__
public/admin

# local-only artifacts
verify-output
preview.bat
*.log

# editor / OS / session state
.claude
.vscode
.idea

# env (never upload)
.env
.env.local
.env.production

# git history (Vercel reconstructs as needed)
.git

# docs that don't need to be on the web server
SETUP.md
FOR-BRIANNA.md

# NOTE: package.json + package-lock.json + astro.config.mjs + tina/config.ts +
# src/ + public/ (except admin) + tools/ + vercel.json MUST deploy so Vercel
# can npm install and run the build.
